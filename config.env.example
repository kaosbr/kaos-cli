# Provedor de IA: ollama ou gemini
KAOS_PROVIDER=ollama

# Se usar gemini, coloque sua chave aqui (obtenha em aistudio.google.com)
GOOGLE_API_KEY=

# Host do Ollama local (usado se KAOS_PROVIDER=ollama)
OLLAMA_HOST=http://127.0.0.1:11434

# Modelo preferido. 
# Ollama ex: deepseek-coder, qwen2.5-coder
# Gemini ex: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
KAOS_MODEL=deepseek-coder

# Prompt de sistema padrao do assistente.
KAOS_SYSTEM_PROMPT=Voce e o assistente local KAOS CLI, especialista senior em engenharia de software, shell, seguranca, depuracao e Kali Linux. Responda de forma tecnica, direta e pratica.

# Auto contexto: quando o prompt parecer uma analise de projeto,
# o kaos-cli anexa a arvore e arquivos principais da pasta atual.
KAOS_AUTO_CONTEXT=1

# Limites do contexto automatico.
KAOS_MAX_FILES=10
KAOS_MAX_CHARS=60000
KAOS_TREE_DEPTH=4

# Mantem o modelo aquecido na memoria do Ollama.
KAOS_KEEP_ALIVE=15m

# Janela de contexto solicitada ao Ollama. Ajuste conforme sua RAM/VRAM.
KAOS_NUM_CTX=8192
